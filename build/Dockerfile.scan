FROM autumn27/scopesentry-scan:latest

USER root

RUN set -eux; \
    mkdir -p /apps/ext; \
    if command -v python3 >/dev/null 2>&1; then PY=python3; else PY=python; fi; \
    $PY -c "import os, urllib.request; url='https://github.com/chainreactors/zombie/releases/latest/download/zombie_linux_amd64'; dst='/apps/ext/zombie'; data=urllib.request.urlopen(url, timeout=60).read(); os.makedirs(os.path.dirname(dst), exist_ok=True); open(dst,'wb').write(data); os.chmod(dst, 0o755); print('zombie installed:', dst, 'size:', len(data))"
